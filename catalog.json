    "memory-save":       { "slug": "memory-save",       "category": "session" },
    "compact":           { "slug": "compact",           "category": "session" },
    "error":             { "slug": "error",             "category": "session" },

    "macropad-click":    { "slug": "click",             "category": "macropad" },
    "macropad-on":       { "slug": "light-on",          "category": "macropad" },
